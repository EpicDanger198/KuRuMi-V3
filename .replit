language = "nodejs"
run = "npm start"
modules = ["nodejs-20"]

[agent]
expertMode = true

[[ports]]
localPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 10294
externalPort = 3000

[[ports]]
localPort = 14271
externalPort = 3001

[[ports]]
localPort = 28514
externalPort = 3002

[[ports]]
localPort = 61038
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[deployment]
deploymentTarget = "cloudrun"
